# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script, version 3.2.0
# ----------------------------------------------------------------------------

# If JAVA_HOME is set, use it; otherwise just let java be found on PATH
if [ -n "$JAVA_HOME" ] ; then
  if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
    JAVACMD="$JAVA_HOME/jre/sh/java"
  else
    JAVACMD="$JAVA_HOME/bin/java"
  fi
  if [ ! -x "$JAVACMD" ] ; then
    die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
  fi
else
  JAVACMD="$(which java 2>/dev/null)"
  if [ -z "$JAVACMD" ] ; then
    die "ERROR: Java not found. Please install Java or set JAVA_HOME."
  fi
fi

MAVEN_OPTS="${MAVEN_OPTS:-}"
MAVEN_DEBUG_OPTS="${MAVEN_DEBUG_OPTS:-}"

# Detect the script directory
APP_HOME="$(cd "$(dirname "$0")" && pwd)"

# Path to wrapper properties
WRAPPER_PROPERTIES="$APP_HOME/.mvn/wrapper/maven-wrapper.properties"

# Read distributionUrl
if [ -f "$WRAPPER_PROPERTIES" ]; then
  DIST_URL=$(grep "^distributionUrl" "$WRAPPER_PROPERTIES" | cut -d'=' -f2-)
else
  echo "ERROR: .mvn/wrapper/maven-wrapper.properties not found."
  exit 1
fi

# Maven home inside user cache
MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
WRAPPER_CACHE="$MAVEN_USER_HOME/wrapper"
MAVEN_NAME=$(basename "$DIST_URL" .zip)
MAVEN_HOME="$WRAPPER_CACHE/$MAVEN_NAME"

# Download + extract Maven if not cached
if [ ! -d "$MAVEN_HOME" ]; then
  mkdir -p "$WRAPPER_CACHE"
  TMP_ZIP="$WRAPPER_CACHE/${MAVEN_NAME}.zip"
  echo "Downloading Maven: $DIST_URL"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$TMP_ZIP" "$DIST_URL"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$TMP_ZIP" "$DIST_URL"
  else
    echo "ERROR: curl or wget required to download Maven."
    exit 1
  fi
  unzip -q "$TMP_ZIP" -d "$WRAPPER_CACHE"
  rm -f "$TMP_ZIP"
fi

MVN_CMD="$MAVEN_HOME/bin/mvn"

exec "$MVN_CMD" "$@"
